name: Build Playz 3DS Browser

permissions:
  contents: write

on:
  push:
    branches: [ "main" ]
    tags: [ "v*" ]
  pull_request:
    branches: [ "main" ]
  workflow_dispatch: {}

jobs:
  # ── Combined Job: Compile everything in the devkitPro container ──────────
  build:
    runs-on: ubuntu-latest
    container: devkitpro/devkitarm:latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Tools (bannertool & makerom)
        run: |
          # The devkitpro container runs as root, so sudo isn't needed
          apt-get update && apt-get install -y curl

          # Install bannertool
          ASSET_BANNER=$(curl -s https://api.github.com/repos/Steveice10/bannertool/releases/latest \
            | grep browser_download_url | grep linux | grep -v '.md5' | head -1 \
            | cut -d'"' -f4)
          curl -L "$ASSET_BANNER" -o /usr/local/bin/bannertool
          chmod +x /usr/local/bin/bannertool

          # Install makerom
          ASSET_MAKEROM=$(curl -s https://api.github.com/repos/3DSGuy/Project_CTR/releases/latest \
            | grep browser_download_url | grep makerom | grep ubuntu | grep -v '.md5' | head -1 \
            | cut -d'"' -f4)
          curl -L "$ASSET_MAKEROM" -o /usr/local/bin/makerom
          chmod +x /usr/local/bin/makerom

      - name: Build .3dsx and .cia
        run: |
          make -j$(nproc)
          make cia

      - name: Upload Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: playz-3ds-browser-build
          path: |
            *.3dsx
            *.smdh
            *.cia

  # ── Job 2: Attach both to a GitHub Release when a tag is pushed ──────────
  release:
    runs-on: ubuntu-latest
    needs: build
    if: startsWith(github.ref, 'refs/tags/v')

    steps:
      - name: Download Artifacts
        uses: actions/download-artifact@v4
        with:
          name: playz-3ds-browser-build

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          files: |
            *.3dsx
            *.cia
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
